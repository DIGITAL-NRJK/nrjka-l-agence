# Database connection string
POSTGRES_URL=postgresql://127.0.0.1:5432/your-database-name
# Used to encrypt JWT tokens
PAYLOAD_SECRET=YOUR_SECRET_HERE
# Used to configure CORS, format links and more. No trailing slash
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
# Secret used to authenticate cron jobs
CRON_SECRET=YOUR_CRON_SECRET_HERE
# Used to validate preview requests
PREVIEW_SECRET=YOUR_SECRET_HERE
# Base de données (Neon) — utilisée par postgresAdapter
DATABASE_URI=postgresql://user:password@host/dbname?sslmode=require

# Stockage des médias — Cloudflare R2 (compatible S3)
S3_BUCKET=nom-de-ton-bucket
S3_ACCESS_KEY_ID=ta-cle-acces-r2
S3_SECRET_ACCESS_KEY=ta-cle-secrete-r2
S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
S3_REGION=auto

# ─────────────────────────────────────────────────────────────
# Chatbot IA (RAG) — fournisseur configurable (schéma compatible OpenAI)
# Le client parle /v1/chat/completions et /v1/embeddings :
# fonctionne avec Mistral managé (défaut) OU un endpoint auto-hébergé (Ollama/vLLM/TGI).
# Le widget s'affiche dès qu'une clé OU AI_BASE_URL est défini.
# ⚠️ Changer d'embedder impose de relancer /reindex-kb (espaces vectoriels incompatibles).

# — Option A : Mistral managé (données en Europe) — https://console.mistral.ai
MISTRAL_API_KEY=ta-cle-mistral
# MISTRAL_CHAT_MODEL=mistral-small-latest   # modèle de génération (optionnel)

# — Option B : tout auto-hébergé sur ton VPS (dé-commenter et adapter) —
# AI_BASE_URL=https://ai.nrjka.com/v1        # génération + embeddings sur le VPS (Ollama/vLLM/TGI)
# AI_API_KEY=le-token-du-reverse-proxy       # optionnel si l'endpoint local n'exige pas d'auth
# AI_CHAT_MODEL=mistral-small                # modèle de génération auto-hébergé
# AI_EMBED_MODEL=bge-m3                       # embedder ouvert (mistral-embed n'est PAS ouvert)

# — Option C : HYBRIDE (recommandé sans GPU) — génération managée + embeddings VPS —
# Laisse MISTRAL_API_KEY ci-dessus pour la génération, et ajoute UNIQUEMENT l'embedder VPS :
# AI_EMBED_BASE_URL=https://ai.nrjka.com/v1  # endpoint embeddings sur le VPS (Ollama derrière reverse proxy)
# AI_EMBED_API_KEY=le-token-du-reverse-proxy # jeton exigé par le reverse proxy devant Ollama
# AI_EMBED_MODEL=bge-m3                       # ⚠️ changer d'embedder => relancer /reindex-kb

# Secret protégeant la route /reindex-kb en production (sinon CRON_SECRET est utilisé)
REINDEX_SECRET=YOUR_REINDEX_SECRET_HERE

# ─────────────────────────────────────────────────────────────
# Email transactionnel — Resend (domaine vérifié via Cloudflare)
# Sert à livrer les ressources « gated » (capture de leads) par email.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM=NRJKA <ressources@nrjka.com>     # expéditeur sur le domaine vérifié
# RESEND_REPLY_TO=hello@nrjka.com             # optionnel (adresse de réponse)